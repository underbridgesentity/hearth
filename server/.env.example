# ---- Database (Neon Postgres in production) ----
# Production: copy your Neon connection string (with ?sslmode=require)
#   postgresql://user:password@ep-xxxx.region.aws.neon.tech/croft?sslmode=require
# Local dev: a local Postgres URL also works.
DATABASE_URL=

# ---- Auth ----
# Long random string used to sign session cookies.
JWT_SECRET=change-me-to-a-long-random-string

# ---- Google sign-in (optional; email auth works without it) ----
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: <SERVER_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- URLs ----
APP_URL=http://localhost:5173
SERVER_URL=http://localhost:3001
PORT=3001
# NODE_ENV=production
